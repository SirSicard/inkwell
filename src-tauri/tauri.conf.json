{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "inkwell",
  "version": "0.1.1",
  "identifier": "com.inkwell.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Inkwell",
        "width": 800,
        "height": 600,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkzODk1RTMwNENBQ0E2NDAKUldSQXBxeE1NRjZKazF5SHVtWnNSREM1bm9rRTcxMkFuWVJKNnJULzNqdVNLalRHOGFKQjZBZEsK",
      "endpoints": [
        "https://inkwell-updater.mattias-e67.workers.dev/api/update/{{target}}/{{arch}}/{{current_version}}"
      ]
    }
  }
}
